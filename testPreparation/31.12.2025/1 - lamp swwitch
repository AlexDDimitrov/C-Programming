#include <stdio.h>

void printLights(unsigned char lights) {
    for(int i = 0; i<8; i++) {
        if (lights & (1<<i)) {
            printf("Lamp %d is on\n", i+1);
        }
        else {
            printf("Lamp %d is off\n", i+1);
        }
    }
}

int main() {
    unsigned char lights = 0;
    while(1) {
        int answer;
        printf("Pick 1 to 3\n   1 - Turn on;\n  2 - Turn off;\n 3 - Switch");
        scanf("%d", &answer);

        printf("Now choose Lamp to do this");
        int answer2;
        scanf("%d", &answer2);

        switch (answer)
        {
            case 1:
                lights |= 1<<(answer2-1);
                break;
            
            case 2:
                lights &= ~(1<<(answer2-1));
                break;
            
            case 3:
                lights ^= 1<<(answer2-1);
                break;

            default:
                break;
        }
        printLights(lights);
    }
}